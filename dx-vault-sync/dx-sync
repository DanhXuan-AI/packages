# --- Phase 3: API Commands ---

# --- Phase 4: Full Loop Autonomy Commands ---

GAP_DETECTOR="$SCRIPT_DIR/scripts/gap_detector.py"
AUTO_RESEARCH="$SCRIPT_DIR/scripts/auto_research.py"
WEEKLY_DIGEST="$SCRIPT_DIR/scripts/weekly_digest.py"
MEMO_BRIDGE="$SCRIPT_DIR/scripts/memo_bridge.py"

cmd_gap_scan() {
    echo -e "${CYAN}Scanning vault for knowledge gaps...${NC}"
    python3 "$GAP_DETECTOR" --vault "$VAULT_PATH" scan
}

cmd_gap_report() {
    banner
    echo -e "${CYAN}Generating gap analysis report...${NC}"
    echo ""
    python3 "$GAP_DETECTOR" --vault "$VAULT_PATH" report
}

cmd_research() {
    local subcmd="${1:-prompt}"
    shift 2>/dev/null || true
    case "$subcmd" in
        prompt)
            echo -e "${CYAN}Generating auto-research prompts...${NC}"
            python3 "$AUTO_RESEARCH" --vault "$VAULT_PATH" prompt
            ;;
        plan)
            python3 "$AUTO_RESEARCH" --vault "$VAULT_PATH" plan
            ;;
        script)
            python3 "$AUTO_RESEARCH" --vault "$VAULT_PATH" script
            ;;
        history)
            python3 "$AUTO_RESEARCH" --vault "$VAULT_PATH" history
            ;;
        store)
            python3 "$AUTO_RESEARCH" --vault "$VAULT_PATH" store "$@"
            ;;
        *)
            echo "Usage: dx-sync research [prompt|plan|script|history|store]"
            ;;
    esac
}

cmd_digest() {
    banner
    local days="${1:-7}"
    echo -e "${CYAN}Generating digest for last $days days...${NC}"
    echo ""
    python3 "$WEEKLY_DIGEST" --vault "$VAULT_PATH" --days "$days" generate
}

cmd_memo() {
    banner
    echo -e "${CYAN}Full Vault Memory Status:${NC}"
    python3 "$MEMO_BRIDGE" --vault "$VAULT_PATH" status
}

cmd_memo_tick() {
    echo -e "${CYAN}Running auto-loop tick...${NC}"
    python3 "$MEMO_BRIDGE" --vault "$VAULT_PATH" tick
}

cmd_claude_md() {
    local output="${1:-}"
    if [ -n "$output" ]; then
        echo -e "${CYAN}Generating CLAUDE.md context → $output${NC}"
        python3 "$MEMO_BRIDGE" --vault "$VAULT_PATH" claude-md --output "$output"
        echo -e "${GREEN}Written to $output${NC}"
    else
        python3 "$MEMO_BRIDGE" --vault "$VAULT_PATH" claude-md
    fi
}

# --- Phase 3: API Commands ---

API_SERVER="$SCRIPT_DIR/api/server.py"

cmd_api() {
    banner
    local port="${1:-8900}"
    echo -e "${CYAN}Starting DX Vault API on port $port...${NC}"
    echo -e "Vault: ${GREEN}$VAULT_PATH${NC}"
    echo -e "Docs:  ${CYAN}http://localhost:$port/docs${NC}"
    echo -e "Spec:  ${CYAN}http://localhost:$port/openapi.json${NC}"
    echo ""
    OBSIDIAN_VAULT_PATH="$VAULT_PATH" DX_VAULT_API_PORT="$port" python3 "$API_SERVER"
}

cmd_api_test() {
    echo -e "${CYAN}Running API tests...${NC}"
    python3 "$SCRIPT_DIR/tests/test_api.py"
}

case "${1:-}" in
    sync)       shift; cmd_sync "$@" ;;
    context)    shift; cmd_context "$@" ;;
    status)     cmd_status ;;
    setup)      cmd_setup ;;
    demo)       cmd_demo ;;
    test)       cmd_test ;;
    biz)        shift; cmd_biz "$@" ;;
    biz-loop)   shift; cmd_biz_loop "$@" ;;
    biz-status) cmd_biz_status ;;
    biz-demo)   cmd_biz_demo ;;
    api)        shift; cmd_api "$@" ;;
    api-test)   cmd_api_test ;;
    gap-scan)   cmd_gap_scan ;;
    gap-report) cmd_gap_report ;;
    research)   shift; cmd_research "$@" ;;
    digest)     shift; cmd_digest "$@" ;;
    memo)       cmd_memo ;;
    memo-tick)  cmd_memo_tick ;;
    claude-md)  shift; cmd_claude_md "$@" ;;
    -h|--help|help|"") usage ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        usage
        exit 1
        ;;
esac
