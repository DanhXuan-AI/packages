{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings.schema.json",
  "_comment": "DX Vault Sync — Claude Code hook configuration. Copy relevant sections to your ~/.claude/settings.json",
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/dx-vault-sync/hooks/on_message.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/dx-vault-sync/hooks/post_conversation.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "OBSIDIAN_VAULT_PATH": "~/ObsidianVault",
    "DX_LEARN_INTERVAL": "6"
  }
}
